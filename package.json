{
	"name": "hr-library",
	"version": "1.0.0",
	"description": "Libreria para mis proyectos con JavaScript, CSS, HTML, con Bootstrap y un sin número de funciones para la web",
	"scripts": {
		"dev": "node scripts/generate-pages.js && vite",
		"build": "node scripts/generate-pages.js && vite build && node scripts/postbuild.js",
		"preview": "vite preview",
		"docs": "jsdoc -c jsdoc.json",
		"lint": "eslint src/js --ext .js",
		"lint:fix": "eslint src/js --ext .js --fix",
		"api": "json-server --watch db.json --port 3001 --routes routes.json --middlewares middleware.js",
		"api:delay": "json-server --watch db.json --port 3001 --routes routes.json --middlewares middleware.js --delay 500",
		"api:reset": "node reset.js"
	},
	"browserslist": [
		">= 0.5%",
		"last 2 major versions",
		"not dead",
		"Chrome >= 60",
		"Firefox >= 60",
		"Firefox ESR",
		"iOS >= 12",
		"Safari >= 12",
		"not Explorer <= 11"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/haisel03/HR-Library.git"
	},
	"keywords": [
		"Libreria",
		"CSS",
		"JS",
		"HTML",
		"Web"
	],
	"author": "Haisel Ramirez <haiselramirez@hotmail.com>",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/haisel03/HR-Library/issues"
	},
	"homepage": "https://github.com/haisel03/HR-Library#readme",
