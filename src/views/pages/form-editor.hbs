{{#> layout-main icon="bi bi-pencil-square" title="Editor de Formularios" description="Demostración de componentes de
formulario enriquecidos, validación y firmas."}}

<div class="row">
    <div class="col-lg-8">
        <!-- Formulario Principal -->
        <div class="card shadow-sm mb-4 card-bt-primary">
            <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
                <h6 class="m-0 fw-bold text-primary"><i class="bi bi-file-earmark-text me-2"></i>Información del
                    Registro</h6>
                <span class="badge bg-light text-primary border">Borrador</span>
            </div>
            <div class="card-body p-4">
                <form id="richForm" novalidate>
                    <!-- Sección 1: Datos Básicos -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nombre Completo</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" class="form-control" name="fullname" required
                                    placeholder="Ej: Juan Pérez">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Correo Electrónico</label>
                            <input type="email" class="form-control" name="email" required
                                placeholder="juan@ejemplo.com">
                        </div>
                    </div>

                    <!-- Sección 2: Selectores y Fechas -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">País (Select2)</label>
                            <select class="form-select select2" name="country" data-placeholder="Selecciona un país">
                                <option></option>
                                <option value="DO">República Dominicana</option>
                                <option value="US">Estados Unidos</option>
                                <option value="ES">España</option>
                                <option value="MX">México</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Fecha de Evento (Flatpickr)</label>
                            <div class="input-group">
                                <input type="text" class="form-control datetimepicker" name="event_date"
                                    placeholder="Elegir fecha...">
                                <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                            </div>
                        </div>
                    </div>

                    <!-- Sección 3: Máscaras -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Teléfono (Máscara)</label>
                            <input type="text" class="form-control" name="phone" data-mask="(000) 000-0000"
                                placeholder="(809) 000-0000">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Cédula</label>
                            <input type="text" class="form-control" name="cedula" data-mask="000-0000000-0"
                                placeholder="000-0000000-0">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Monto (Currency)</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="text" class="form-control text-end" name="amount" placeholder="0.00">
                            </div>
                        </div>
                    </div>

                    <!-- Sección 4: Editor de Texto Enriquecido -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Descripción Detallada (Quill)</label>
                        <div id="full-editor" style="height: 250px;">
                            <p>Escribe aquí los detalles del registro...</p>
                        </div>
                    </div>

                    <!-- Sección 5: Firma Electrónica -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold d-block">Firma del Solicitante</label>
                        <div class="signature-wrapper border rounded bg-light position-relative" style="height: 200px;">
                            <canvas id="signature-pad" class="w-100 h-100"></canvas>
                            <button type="button" id="clear-signature"
                                class="btn btn-sm btn-outline-secondary position-absolute top-0 end-0 m-2">
                                <i class="bi bi-eraser me-1"></i> Limpiar
                            </button>
                        </div>
                        <input type="hidden" name="signature" id="signature-input">
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light px-4" id="btnReset">Reiniciar</button>
                        <button type="submit" class="btn btn-primary px-5">Guardar Registro</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Panel Lateral de Información -->
    <div class="col-lg-4">
        <div class="card shadow-sm mb-4 border-0 bg-navy text-white">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Guía Rápida</h5>
                <p class="small opacity-75">Este formulario utiliza los helpers core de la librería <code>HR</code> para
                    autogestionar componentes complejos.</p>
                <ul class="list-unstyled small mb-0">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Select2:</strong>
                        Búsqueda instantánea.</li>
                    <li class="mb-2"><i
                            class="bi bi-check-circle-fill text-success me-2"></i><strong>Flatpickr:</strong> Manejo de
                        fechas ISO.</li>
                    <li class="mb-2"><i
                            class="bi bi-check-circle-fill text-success me-2"></i><strong>Inputmask:</strong> Validación
                        de formato.</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Quill:</strong>
                        Formato de texto profesional.</li>
                </ul>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 fw-bold text-dark">Data Debugger</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-2">JSON generado en tiempo real:</p>
                <pre id="form-debugger" class="bg-light p-3 rounded small border mb-0"
                    style="max-height: 400px; overflow-y: auto;">{}</pre>
            </div>
        </div>
    </div>
</div>

{{/layout-main}}

<style>
    .card-bt-primary {
        border-top: 4px solid var(--bs-primary);
    }

    .signature-wrapper canvas {
        cursor: crosshair;
        touch-action: none;
    }

    .input-group-text {
        background-color: #f8f9fa;
        border-right: 0;
    }

    .input-group .form-control {
        border-left: 0;
    }

    .input-group .form-control:focus {
        border-left: 1px solid #86b7fe;
    }

    pre {
        font-family: 'Courier New', Courier, monospace;
    }
</style>

<script src="demos/form-editor.js"></script>
