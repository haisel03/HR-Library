                        </ul>
                        <a href="#" class="btn btn-primary w-100">Comenzar</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border h-100 shadow-none">
                    <div class="card-body p-4 text-center">
                        <h5 class="text-uppercase text-muted mb-4">Enterprise</h5>
                        <h2 class="display-4 fw-bold mb-4">Custom</h2>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2">Alumnos Ilimitados</li>
                            <li class="mb-2">Todos los Módulos</li>
                            <li class="mb-2">Desarrollos a Medida</li>
                            <li class="mb-2">Gerente de Cuenta Dedicado</li>
                        </ul>
                        <a href="#" class="btn btn-outline-primary w-100">Contactar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
