                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4 mb-lg-0">
                <div class="card border-primary h-100 shadow-sm scale-1">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h5 class="mb-0 text-white">Recomendado</h5>
                    </div>
                    <div class="card-body p-4 text-center">
                        <h5 class="text-uppercase text-muted mb-4">Mediano</h5>
                        <h2 class="display-4 fw-bold mb-4">$149<small class="fs-5 text-muted">/mes</small></h2>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2">Hasta 800 Alumnos</li>
                            <li class="mb-2">Académico + Financiero</li>
                            <li class="mb-2">App Móvil Incluida</li>
