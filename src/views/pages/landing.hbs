<!-- CTA -->
<section class="py-5 bg-primary text-white text-center">
    <div class="container">
        <h2 class="fw-bold mb-4">¿Listo para modernizar tu escuela?</h2>
        <a href="login.html" class="btn btn-light btn-lg px-5">Solicitar Demo Gratuita</a>
    </div>
</section>

