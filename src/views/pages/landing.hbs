{{#> layout-landing}}

<!-- Hero Section -->
<section class="bg-dark text-white py-5 py-lg-6 position-relative overflow-hidden">
    <div class="container position-relative z-1">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <h1 class="display-3 fw-bold mb-4 animate__animated animate__fadeInUp">Gestión Escolar Inteligente para
                    el Futuro</h1>
                <p class="lead mb-4 text-white-50 animate__animated animate__fadeInUp animate__delay-1s">
                    Simplifica la administración de tu centro educativo con EduMatrix. Calificaciones, asistencia,
                    finanzas y comunicación en una sola plataforma.
                </p>
                <div class="d-flex gap-3 animate__animated animate__fadeInUp animate__delay-2s">
                    <a href="login.html" class="btn btn-primary btn-lg px-4">Prueba Demo</a>
                    <a href="#features" class="btn btn-outline-light btn-lg px-4">Saber Más</a>
                </div>
            </div>
            <div class="col-lg-6">
                <img src="https://source.unsplash.com/random/800x600/?school,technology"
                    class="img-fluid rounded-3 shadow-lg animate__animated animate__fadeInRight"
                    alt="Dashboard Preview">
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 bg-white border-bottom">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-4 mb-md-0">
                <h2 class="fw-bold text-primary display-4">500+</h2>
                <p class="text-muted h5">Escuelas Activas</p>
            </div>
            <div class="col-md-4 mb-4 mb-md-0">
                <h2 class="fw-bold text-primary display-4">150k</h2>
                <p class="text-muted h5">Estudiantes</p>
            </div>
            <div class="col-md-4">
                <h2 class="fw-bold text-primary display-4">99.9%</h2>
                <p class="text-muted h5">Uptime Garantizado</p>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section id="features" class="py-5 py-lg-6 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Todo lo que necesitas en un solo lugar</h2>
            <p class="text-muted lead">Módulos integrados para cada departamento de tu institución.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="card-body">
                        <div class="mb-3 text-primary"><i class="bi bi-mortarboard fs-1"></i></div>
                        <h4 class="card-title">Académico</h4>
                        <p class="card-text text-muted">Gestión de inscripciones, calificaciones, boletines automáticos
                            y control de asistencia.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="card-body">
                        <div class="mb-3 text-success"><i class="bi bi-cash-coin fs-1"></i></div>
                        <h4 class="card-title">Financiero</h4>
                        <p class="card-text text-muted">Facturación recurrente, control de pagos, reportes de morosidad
                            y nómina docente.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="card-body">
                        <div class="mb-3 text-info"><i class="bi bi-chat-dots fs-1"></i></div>
                        <h4 class="card-title">Comunicación</h4>
                        <p class="card-text text-muted">Portal para padres, notificaciones push, mensajería interna y
                            envío de circulares.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="card-body">
                        <div class="mb-3 text-warning"><i class="bi bi-bus-front fs-1"></i></div>
                        <h4 class="card-title">Transporte</h4>
                        <p class="card-text text-muted">Gestión de rutas escolares, seguimiento GPS y notificaciones de
                            llegada.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="card-body">
                        <div class="mb-3 text-danger"><i class="bi bi-shield-check fs-1"></i></div>
                        <h4 class="card-title">Seguridad</h4>
                        <p class="card-text text-muted">Roles y permisos granulares, backups automáticos y encriptación
                            de datos.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    <div class="card-body">
                        <div class="mb-3 text-dark"><i class="bi bi-phone fs-1"></i></div>
                        <h4 class="card-title">App Móvil</h4>
                        <p class="card-text text-muted">Aplicación nativa para iOS y Android para padres, alumnos y
                            profesores.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

