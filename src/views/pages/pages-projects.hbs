{{#> layout-main icon="bi bi-folder" title="Proyectos" description="Gestión de proyectos y seguimiento."}}

<div class="container-fluid p-0">

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="card-actions float-end">
                        <a href="#" class="btn btn-primary"><i class="fas fa-plus"></i> Nuevo Proyecto</a>
                    </div>
                    <h5 class="card-title mb-0">Proyectos Activos</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped projects">
                        <thead>
                            <tr>
                                <th style="width: 1%">#</th>
                                <th style="width: 20%">Nombre del Proyecto</th>
                                <th style="width: 30%">Equipo</th>
                                <th>Progreso</th>
                                <th style="width: 8%" class="text-center">Estado</th>
                                <th style="width: 20%">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>#</td>
                                <td>
                                    <a>AdminLTE v4</a>
                                    <br>
                                    <small>Created 01.01.2023</small>
                                </td>
                                <td>
                                    <ul class="list-inline">
                                        <li class="list-inline-item">
                                            <img alt="Avatar" class="rounded-circle" width="30"
                                                src="img/avatars/avatar.jpg">
                                        </li>
                                        <li class="list-inline-item">
                                            <img alt="Avatar" class="rounded-circle" width="30"
                                                src="img/avatars/avatar-2.jpg">
                                        </li>
                                    </ul>
                                </td>
                                <td class="project_progress">
                                    <div class="progress progress-sm">
                                        <div class="progress-bar bg-green" role="progressbar" aria-valuenow="57"
                                            aria-valuemin="0" aria-valuemax="100" style="width: 57%">
                                        </div>
                                    </div>
                                    <small>57% Complete</small>
                                </td>
                                <td class="project-state">
                                    <span class="badge bg-success">Success</span>
                                </td>
                                <td class="project-actions text-right">
                                    <a class="btn btn-primary btn-sm" href="#"><i class="fas fa-folder"></i> Ver</a>
                                    <a class="btn btn-info btn-sm" href="#"><i class="fas fa-pencil-alt"></i> Editar</a>
                                    <a class="btn btn-danger btn-sm" href="#"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                            <tr>
                                <td>#</td>
                                <td>
                                    <a>EduMatrix CRM</a>
                                    <br>
                                    <small>Created 10.05.2023</small>
                                </td>
                                <td>
                                    <ul class="list-inline">
                                        <li class="list-inline-item">
                                            <img alt="Avatar" class="rounded-circle" width="30"
                                                src="img/avatars/avatar-3.jpg">
                                        </li>
                                        <li class="list-inline-item">
                                            <img alt="Avatar" class="rounded-circle" width="30"
                                                src="img/avatars/avatar-4.jpg">
                                        </li>
                                    </ul>
                                </td>
                                <td class="project_progress">
                                    <div class="progress progress-sm">
                                        <div class="progress-bar bg-warning" role="progressbar" aria-valuenow="77"
                                            aria-valuemin="0" aria-valuemax="100" style="width: 77%">
                                        </div>
                                    </div>
                                    <small>77% Complete</small>
                                </td>
                                <td class="project-state">
                                    <span class="badge bg-warning">En Progreso</span>
                                </td>
                                <td class="project-actions text-right">
                                    <a class="btn btn-primary btn-sm" href="#"><i class="fas fa-folder"></i> Ver</a>
                                    <a class="btn btn-info btn-sm" href="#"><i class="fas fa-pencil-alt"></i> Editar</a>
                                    <a class="btn btn-danger btn-sm" href="#"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{{/layout-main}}