{{#> layout-main icon="bi bi-server" title="DataTable con API" description="Ejemplo de tabla que carga datos desde
jsonplaceholder.typicode.com"}}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Usuarios (API Externa)</h5>
            </div>
            <div class="card-body">
                <table id="api-table" class="table table-striped" style="width:100%">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Usuario</th>
                            <th>Email</th>
                            <th>Ciudad</th>
                            <th>Compañía</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{{/layout-main}}