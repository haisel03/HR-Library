{{#> layout-main icon="bi bi-people-fill" title="Directorio de Estudiantes" description="Gestión del alumnado activo"}}

<div class="row mb-3">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="row g-2 align-items-center">
                    <div class="col-md-3">
                        <input type="text" class="form-control" placeholder="Buscar por nombre, matrícula...">
                    </div>
                    <div class="col-md-3">
                        <select class="form-select">
                            <option selected>Todos los Grados</option>
                            <option>1ro Primaria</option>
                            <option>1ro Secundaria</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select">
                            <option selected>Todos los Estados</option>
                            <option>Activo</option>
                            <option>Retirado</option>
                            <option>Graduado</option>
                        </select>
                    </div>
                    <div class="col-md-3 text-end">
                        <button class="btn btn-primary"><i class="bi bi-person-plus"></i> Nuevo Estudiante</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

