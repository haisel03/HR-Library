{{#> layout-main icon="bi bi-buildings" title="Gestión Multi-Escuela" description="Administración de centros educativos
registrados"}}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white h-100">
            <div class="card-body">
                <h3 class="text-white">12</h3>
                <span>Escuelas Activas</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white h-100">
            <div class="card-body">
                <h3 class="text-white">3,500</h3>
                <span>Estudiantes Totales</span>
            </div>
        </div>
    </div>
    <div class="col-md-6 text-end align-self-center">
        <button class="btn btn-primary btn-lg"><i class="bi bi-plus-circle"></i> Registrar Nuevo Centro</button>
    </div>
</div>

<div class="row">
    <!-- School Card -->
    <div class="col-lg-6 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="row g-0 h-100">
                <div class="col-md-4 bg-light d-flex align-items-center justify-content-center">
                    <i class="bi bi-building fs-1 text-muted"></i>
                </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title fw-bold">Colegio San José</h5>
                            <span class="badge bg-success">Activo</span>
                        </div>
                        <p class="card-text text-muted small">ID: SCH-001 • Plan Premium</p>

                        <div class="row text-center my-3 small">
                            <div class="col-4 border-end">500 <br> Alumnos</div>
                            <div class="col-4 border-end">35 <br> Profes</div>
                            <div class="col-4">RD$ 2M <br> Ingresos</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm w-100">Administrar</button>
                            <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- School Card -->
    <div class="col-lg-6 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="row g-0 h-100">
                <div class="col-md-4 bg-light d-flex align-items-center justify-content-center">
                    <i class="bi bi-bank fs-1 text-muted"></i>
                </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title fw-bold">Instituto Moderno</h5>
                            <span class="badge bg-success">Activo</span>
                        </div>
                        <p class="card-text text-muted small">ID: SCH-002 • Plan Básico</p>

                        <div class="row text-center my-3 small">
                            <div class="col-4 border-end">150 <br> Alumnos</div>
                            <div class="col-4 border-end">12 <br> Profes</div>
                            <div class="col-4">RD$ 500k <br> Ingresos</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm w-100">Administrar</button>
                            <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- School Card -->
    <div class="col-lg-6 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="row g-0 h-100">
                <div class="col-md-4 bg-light d-flex align-items-center justify-content-center">
                    <i class="bi bi-house fs-1 text-muted"></i>
                </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title fw-bold">Escuela Básica Futuro</h5>
                            <span class="badge bg-danger">Suspendido</span>
                        </div>
                        <p class="card-text text-muted small">ID: SCH-003 • Plan Gratuito</p>

                        <div class="row text-center my-3 small">
                            <div class="col-4 border-end">50 <br> Alumnos</div>
                            <div class="col-4 border-end">5 <br> Profes</div>
                            <div class="col-4">RD$ 0 <br> Ingresos</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm w-100 disabled">Administrar</button>
                            <button class="btn btn-outline-danger btn-sm"><i
                                    class="bi bi-exclamation-circle"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{{/layout-main}}