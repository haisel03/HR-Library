{{#> layout-main icon="bi bi-wallet2" title="Registro de Gastos" description="Control de gastos operativos"}}

<div class="row">
	<div class="col-12">
		<div class="card">
			<div class="card-header d-flex justify-content-between align-items-center">
				<h5 class="card-title mb-0"><i class="bi bi-list me-2"></i>Listado de Gastos</h5>
				<button class="btn btn-danger"><i class="bi bi-dash-circle me-2"></i>Registrar Nuevo Gasto</button>
			</div>
			<div class="card-body">
				<table class="table table-striped table-hover">
					<thead>
						<tr>
							<th>Fecha</th>
							<th>Descripción</th>
							<th>Categoría</th>
							<th>Proveedor</th>
							<th>Monto</th>
							<th>Aprobado Por</th>
							<th>Adjunto</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>15 Oct 2023</td>
							<td>Mantenimiento Aires Acondicionados</td>
							<td><span class="badge bg-secondary">Mantenimiento</span></td>
							<td>Servicios Clima SRL</td>
							<td class="text-danger fw-bold">RD$ 8,500.00</td>
							<td>Admin</td>
							<td><i class="bi bi-paperclip text-muted"></i></td>
						</tr>
						<tr>
							<td>12 Oct 2023</td>
							<td>Compra Papelería Oficina</td>
							<td><span class="badge bg-secondary">Suministros</span></td>
							<td>Librería Universal</td>
							<td class="text-danger fw-bold">RD$ 3,200.00</td>
							<td>Secretaría</td>
							<td><i class="bi bi-paperclip text-muted"></i></td>
						</tr>
						<tr>
							<td>01 Oct 2023</td>
							<td>Pago Internet y Teléfono</td>
							<td><span class="badge bg-secondary">Servicios Básicos</span></td>
							<td>Claro</td>
							<td class="text-danger fw-bold">RD$ 4,500.00</td>
							<td>Admin</td>
							<td><i class="bi bi-paperclip text-muted"></i></td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

{{/layout-main}}
