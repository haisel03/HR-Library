{{#> layout-main icon="bi bi-window-stack" title="Panel Multi-Ventana" description="Modo Iframe para navegación con
pestañas simultáneas."}}

<div class="iframe-mode-wrapper bg-light border rounded shadow-sm d-flex flex-column"
	style="height: calc(100vh - 180px);">
	<!-- Header de Tabs -->
	<div class="iframe-mode-header bg-white border-bottom d-flex align-items-center p-0">
		<div class="dropdown border-end">
			<button class="btn btn-link text-danger dropdown-toggle rounded-0 py-2 border-0" type="button"
				data-bs-toggle="dropdown">
				Cerrar
			</button>
			<ul class="dropdown-menu shadow nav">
				<li class="nav-item"><a class="nav-link" href="#" id="btnCloseAll">Cerrar Todo</a></li>
				<li class="nav-item"><a class="nav-link" href="#" id="btnCloseOthers">Cerrar los Demás</a></li>
			</ul>
		</div>

		<div class="flex-grow-1 overflow-hidden">
			<ul class="nav nav-pills nav-tabs-iframe flex-nowrap mb-0" id="iframe-tabs" role="tablist"
				style="overflow-x: auto;">
				<!-- Tabs se insertan aquí -->
			</ul>
		</div>

		<div class="d-flex border-start">
			<button class="btn btn-link text-dark py-2 border-0 rounded-0" id="btnIframeRefresh" title="Actualizar">
				<i class="bi bi-arrow-clockwise"></i>
			</button>
			<button class="btn btn-link text-dark py-2 border-0 rounded-0" id="btnIframeFullscreen" title="Pantalla Completa">
				<i class="bi bi-arrows-fullscreen"></i>
			</button>
		</div>
	</div>

	<!-- Contenedor de Iframes -->
	<div class="tab-content flex-grow-1 position-relative" id="iframe-contents">
		<div class="tab-empty d-flex align-items-center justify-content-center h-100 flex-column text-muted opacity-50">
			<i class="bi bi-window-plus display-1 mb-3"></i>
			<h4 class="fw-bold">No hay pestañas abiertas</h4>
			<p>Selecciona una opción del menú lateral para comenzar.</p>
		</div>
	</div>
</div>

{{/layout-main}}
