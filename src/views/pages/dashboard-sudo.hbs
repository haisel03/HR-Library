{{#> layout-main icon="bi bi-shield-lock-fill" title="SUDO Dashboard" description="Vista Global de Super
Administrador"}}

<div class="row">
    <div class="col-md-3">
        <div class="card bg-dark text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 text-uppercase mb-1">Escuelas Activas</h6>
                        <h2 class="mb-0 fw-bold text-white">12</h2>
                    </div>
                    <i class="bi bi-buildings fs-1 text-white-50"></i>
                </div>
                <div class="mt-3">
                    <span class="badge bg-success">+2 este mes</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 text-uppercase mb-1">Usuarios Totales</h6>
                        <h2 class="mb-0 fw-bold text-white">4,250</h2>
                    </div>
                    <i class="bi bi-people fs-1 text-white-50"></i>
                </div>
                <div class="mt-3">
                    <small>3,500 Alumnos / 250 Docentes</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 text-uppercase mb-1">Ingresos SaaS</h6>
                        <h2 class="mb-0 fw-bold text-white">$12,500</h2>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 text-white-50"></i>
                </div>
                <div class="mt-3">
                    <small>Facturación Mensual Recurrente</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-dark-50 text-uppercase mb-1">Soporte</h6>
                        <h2 class="mb-0 fw-bold text-dark">5</h2>
                    </div>
                    <i class="bi bi-ticket-perforated fs-1 text-dark-50"></i>
                </div>
                <div class="mt-3">
                    <small>Tickets abiertos hoy</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title">Crecimiento de la Plataforma</h5>
            </div>
            <div class="card-body">
                <div class="chart-area" style="height: 350px;">
                    <!-- Placeholder for ChartJS -->
                    <canvas id="chartjs-dashboard-line"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title">Últimas Escuelas Registradas</h5>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1 fw-bold">Colegio San José</h6>
                        <small class="text-muted">Hace 2 días</small>
                    </div>
                    <p class="mb-1 small">Plan Premium - 500 Alumnos</p>
                    <small class="text-success"><i class="bi bi-check-circle"></i> Verificado</small>
                </div>
                <div class="list-group-item">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1 fw-bold">Instituto Bilingüe Futuro</h6>
                        <small class="text-muted">Hace 5 días</small>
                    </div>
                    <p class="mb-1 small">Plan Básico - 150 Alumnos</p>
                    <small class="text-warning"><i class="bi bi-clock"></i> Pendiente Pago</small>
                </div>
                <div class="list-group-item">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1 fw-bold">Escuela Montessori</h6>
                        <small class="text-muted">Hace 1 semana</small>
                    </div>
                    <p class="mb-1 small">Plan Trial - 50 Alumnos</p>
                    <small class="text-primary"><i class="bi bi-star"></i> En Prueba</small>
                </div>
            </div>
            <div class="card-footer text-center">
                <a href="admin-schools.html" class="btn btn-sm btn-primary">Gestionar Todas</a>
            </div>
        </div>
    </div>
</div>

{{/layout-main}}