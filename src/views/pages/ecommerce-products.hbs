{{#> layout-main icon="bi bi-cart4" title="Catálogo de Productos" description="Gestión y visualización de productos
institucionales."}}

<div class="container-fluid p-0">
	<div class="row">
		<div class="col-12 col-sm-6 col-md-4 col-lg-3">
			<div class="card shadow-sm border-0">
				<img class="card-img-top" src="img/photos/unsplash-1.jpg" alt="Producto">
				<div class="card-body">
					<h5 class="card-title mb-1">Producto Demo 1</h5>
					<p class="text-muted mb-2 font-size-sm">Categoria</p>
					<div class="d-flex align-items-center mb-3">
						<h4 class="mb-0">RD$ 49.99</h4>
					</div>
					<button type="button" class="btn btn-primary w-100">Añadir al Carrito</button>
				</div>
			</div>
		</div>
		<div class="col-12 col-sm-6 col-md-4 col-lg-3">
			<div class="card shadow-sm border-0">
				<img class="card-img-top" src="img/photos/unsplash-2.jpg" alt="Producto">
				<div class="card-body">
					<h5 class="card-title mb-1">Producto Demo 2</h5>
					<p class="text-muted mb-2 font-size-sm">Electrónica</p>
					<div class="d-flex align-items-center mb-3">
						<h4 class="mb-0">RD$ 149.99</h4>
					</div>
					<button type="button" class="btn btn-primary w-100">Añadir al Carrito</button>
				</div>
			</div>
		</div>
		<div class="col-12 col-sm-6 col-md-4 col-lg-3">
			<div class="card shadow-sm border-0">
				<img class="card-img-top" src="img/photos/unsplash-3.jpg" alt="Producto">
				<div class="card-body">
					<h5 class="card-title mb-1">Producto Demo 3</h5>
					<p class="text-muted mb-2 font-size-sm">Hogar</p>
					<div class="d-flex align-items-center mb-3">
						<h4 class="mb-0">RD$ 29.00</h4>
					</div>
					<button type="button" class="btn btn-primary w-100">Añadir al Carrito</button>
				</div>
			</div>
		</div>
		<div class="col-12 col-sm-6 col-md-4 col-lg-3">
			<div class="card shadow-sm border-0">
				<div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
					<i class="bi bi-image fs-1 text-muted opacity-50"></i>
				</div>
				<div class="card-body">
					<h5 class="card-title mb-1">Producto Sin Imagen</h5>
					<p class="text-muted mb-2 font-size-sm">Servicios</p>
					<div class="d-flex align-items-center mb-3">
						<h4 class="mb-0">RD$ 99.00</h4>
					</div>
					<button type="button" class="btn btn-primary w-100">Añadir al Carrito</button>
				</div>
			</div>
		</div>
	</div>
</div>

</div>


{{/layout-main}}
