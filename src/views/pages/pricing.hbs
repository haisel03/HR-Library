{{#> layout-main icon="bi bi-tags" title="Planes y Precios" description="Elige el plan que mejor se adapte a tus
necesidades"}}

<div class="container-fluid p-0">

	<div class="row">
		<div class="col-md-10 col-lg-8 mx-auto ">
			<div class="row">
				<div class="col-sm-4 mb-3 mb-md-0">
					<div class="card text-center h-100 shadow-sm border-0">
						<div class="card-body d-flex flex-column">
							<div class="mb-4">
								<h5 class="text-muted">Básico</h5>
								<span class="display-4 text-primary">RD$ 1,900</span>
								<span>/mes</span>
								<p class="text-sm mt-2">Ideal para equipos pequeños</p>
							</div>
							<h6>Incluye:</h6>
							<ul class="list-unstyled">
								<li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Usuarios ilimitados</li>
								<li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>5GB almacenamiento</li>
								<li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Soporte estándar</li>
								<li class="mb-2 text-muted opacity-50 text-decoration-line-through"><i
										class="bi bi-x text-danger me-2"></i>Integraciones API</li>
							</ul>
							<div class="mt-auto pt-3">
								<button type="button" class="btn btn-lg btn-outline-primary w-100 btn-select-plan">Seleccionar</button>
							</div>
						</div>
					</div>
				</div>
				<div class="col-sm-4 mb-3 mb-md-0">
					<div class="card text-center h-100 border-primary shadow" style="transform: scale(1.05); z-index: 10;">
						<div class="badge bg-primary position-absolute top-0 start-50 translate-middle">RECOMENDADO
						</div>
						<div class="card-body d-flex flex-column">
							<div class="mb-4 pt-2">
								<h5 class="text-primary fw-bold">Profesional</h5>
								<span class="display-4 text-primary">RD$ 4,900</span>
								<span>/mes</span>
								<p class="text-sm mt-2">Para instituciones en crecimiento</p>
							</div>
							<h6>Incluye:</h6>
							<ul class="list-unstyled">
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>Usuarios ilimitados
								</li>
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>50GB almacenamiento
								</li>
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>Soporte prioritario
								</li>
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>Integraciones básicas
								</li>
							</ul>
							<div class="mt-auto pt-3">
								<button type="button" class="btn btn-lg btn-primary w-100 btn-select-plan">Seleccionar
									Plan</button>
							</div>
						</div>
					</div>
				</div>
				<div class="col-sm-4 mb-3 mb-md-0">
					<div class="card text-center h-100 shadow-sm border-0">
						<div class="card-body d-flex flex-column">
							<div class="mb-4">
								<h5 class="text-muted">Institucional</h5>
								<span class="display-4 text-primary">RD$ 9,900</span>
								<span>/mes</span>
								<p class="text-sm mt-2">Solución a medida enterprise</p>
							</div>
							<h6>Incluye:</h6>
							<ul class="list-unstyled">
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>Usuarios ilimitados
								</li>
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>Almacenamiento
									Ilimitado</li>
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>Soporte 24/7 VIP</li>
								<li class="mb-2"><i class="bi bi-check2-all text-success me-2"></i>Seguridad Avanzada
								</li>
							</ul>
							<div class="mt-auto pt-3">
								<button type="button" class="btn btn-lg btn-outline-primary w-100" id="btn-ventas">Contactar
									Ventas</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

</div>


{{/layout-main}}
