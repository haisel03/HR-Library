{{#> layout-main icon="bi bi-diagram-3" title="Cursos y Secciones" description="Estructura académica y cupos"}}

<div class="row">
    <div class="col-12 col-lg-8">
        <div class="card">
            <div class="card-header">
                <div class="card-actions float-end">
                    <button class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Nueva Sección</button>
                </div>
                <h5 class="card-title">Oferta Académica 2023-2024</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nivel</th>
                            <th>Grado</th>
                            <th>Sección</th>
                            <th>Cupo</th>
                            <th>Inscritos</th>
                            <th>Tutor</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Primaria -->
                        <tr class="table-light">
                            <td colspan="8" class="fw-bold text-primary">Nivel Primario</td>
                        </tr>
                        <tr>
                            <td>Primaria</td>
                            <td>1ro</td>
                            <td><span class="badge bg-light text-dark border">A</span></td>
                            <td>30</td>
                            <td>
                                <div class="progress" style="height: 6px; width: 60px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 90%"
                                        aria-valuenow="90" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted">27/30</small>
                            </td>
                            <td>Laura M.</td>
                            <td><span class="badge bg-success">Abierto</span></td>
                            <td class="text-end">
                                <a href="#"><i class="bi bi-pencil-square text-muted"></i></a>
                            </td>
                        </tr>
                        <tr>
                            <td>Primaria</td>
                            <td>2do</td>
                            <td><span class="badge bg-light text-dark border">A</span></td>
                            <td>30</td>
                            <td>
                                <div class="progress" style="height: 6px; width: 60px;">
                                    <div class="progress-bar bg-warning" role="progressbar" style="width: 100%"
                                        aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted">30/30</small>
                            </td>
                            <td>Patricia R.</td>
                            <td><span class="badge bg-warning">Lleno</span></td>
                            <td class="text-end">
                                <a href="#"><i class="bi bi-pencil-square text-muted"></i></a>
                            </td>
                        </tr>

                        <!-- Secundaria -->
                        <tr class="table-light">
                            <td colspan="8" class="fw-bold text-primary">Nivel Secundario</td>
                        </tr>
                        <tr>
                            <td>Secundaria</td>
                            <td>4to</td>
                            <td><span class="badge bg-light text-dark border">A</span></td>
                            <td>35</td>
                            <td>
                                <div class="progress" style="height: 6px; width: 60px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 80%"
                                        aria-valuenow="80" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted">28/35</small>
                            </td>
                            <td>Pedro S.</td>
                            <td><span class="badge bg-success">Abierto</span></td>
                            <td class="text-end">
                                <a href="#"><i class="bi bi-pencil-square text-muted"></i></a>
                            </td>
                        </tr>
                        <tr>
                            <td>Secundaria</td>
                            <td>5to</td>
                            <td><span class="badge bg-light text-dark border">A</span></td>
                            <td>35</td>
                            <td>
                                <div class="progress" style="height: 6px; width: 60px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 50%"
                                        aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-muted">17/35</small>
                            </td>
                            <td>Julio V.</td>
                            <td><span class="badge bg-success">Abierto</span></td>
                            <td class="text-end">
                                <a href="#"><i class="bi bi-pencil-square text-muted"></i></a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Resumen de Capacidad</h5>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="fw-bold">Primaria</span>
                        <span>85% Ocupación</span>
                    </div>
                    <div class="progress mb-3">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 85%" aria-valuenow="85"
                            aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="fw-bold">Secundaria</span>
                        <span>70% Ocupación</span>
                    </div>
                    <div class="progress mb-3">
                        <div class="progress-bar bg-info" role="progressbar" style="width: 70%" aria-valuenow="70"
                            aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Atención:</strong> 2do de Primaria ha alcanzado su capacidad máxima. Considere abrir Sección
                    B.
                </div>
            </div>
        </div>
    </div>
</div>

{{/layout-main}}