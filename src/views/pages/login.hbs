{{#> layout-auth
title="Iniciar Sesión"
description="Bienvenido de nuevo a HR-Library. Ingresa tus credenciales para continuar."}}

<div class="card">
	<div class="card-body">

		<form id="loginForm">

			<!-- EMAIL -->
			<div class="form-floating mb-4">
				<input type="email" class="form-control" id="email" name="email" placeholder="correo@ejemplo.com" required>
				<label for="email">
					<i class="bi bi-envelope me-1"></i> Correo Electrónico
				</label>
			</div>

			<!-- PASSWORD -->
			<div class="form-floating mb-3 password-wrapper">
				<input type="password" class="form-control" id="password" name="password" placeholder="Contraseña" required>
				<label for="password">
					<i class="bi bi-lock me-1"></i> Contraseña
				</label>

				<i class="bi bi-eye toggle-password" id="togglePassword"></i>
			</div>

			<div class="text-end mb-3">
				<a href="reset-password.html" class="text-muted small">
					¿Olvidaste tu contraseña?
				</a>
			</div>

			<!-- REMEMBER -->
			<div class="form-check form-switch mb-4">
				<input class="form-check-input" type="checkbox" id="rememberMe" name="remember">
				<label class="form-check-label" for="rememberMe">
					Recordar sesión
				</label>
			</div>

			<!-- BUTTON -->
			<div class="d-grid">
				<button type="submit" class="btn btn-primary btn-lg">
					<i class="bi bi-box-arrow-in-right me-2"></i>
					Acceder al Portal
				</button>
			</div>

		</form>

	</div>
</div>

<div class="text-center mt-4 auth-footer">
	¿No tienes una cuenta? <a href="#">Solicitar acceso</a>
</div>

{{/layout-auth}}

{{#*inline "js"}}
<script src="js/demos/login.js"></script>
{{/inline}}
