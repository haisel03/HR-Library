{{#> layout-main icon="bi bi-headset" title="Recepción y Secretaría" description="Panel de control administrativo"}}

<div class="row">
    <!-- Quick Search -->
    <div class="col-12 mb-4">
        <div class="card bg-primary text-white">
            <div class="card-body p-4">
                <h3 class="text-white mb-3">¿A quién buscas?</h3>
                <div class="input-group input-group-lg">
                    <input type="text" class="form-control border-0"
                        placeholder="Escribe el nombre del estudiante, padre o profesor...">
                    <button class="btn btn-light text-primary" type="button"><i class="bi bi-search"></i>
                        Buscar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-4 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-cake2 text-danger me-2"></i> Cumpleaños de Hoy</h5>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item d-flex align-items-center">
                    <img src="img/avatars/avatar.jpg" class="rounded-circle me-3" width="40">
                    <div>
                        <h6 class="mb-0">Juanito Pérez</h6>
                        <small class="text-muted">1ro Primaria • 7 años</small>
                    </div>
                    <i class="bi bi-gift ms-auto text-danger fs-4"></i>
                </div>
                <div class="list-group-item d-flex align-items-center">
                    <img src="img/avatars/avatar-4.jpg" class="rounded-circle me-3" width="40">
                    <div>
                        <h6 class="mb-0">Prof. Rosa</h6>
                        <small class="text-muted">Coordinación</small>
                    </div>
                    <i class="bi bi-gift ms-auto text-danger fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Solicitudes de Admisión</h5>
                <span class="badge bg-danger rounded-pill">3 Nuevas</span>
            </div>
            <div class="list-group list-group-flush">
                <a href="admin-admissions.html" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1 text-primary fw-bold">Familia Martínez</h6>
                        <small>10 min</small>
                    </div>
                    <p class="mb-1 small">Información para 2 niños (Primaria)</p>
                </a>
                <a href="admin-admissions.html" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1 text-primary fw-bold">Sra. Carmen Diaz</h6>
                        <small>1 hora</small>
                    </div>
                    <p class="mb-1 small">Solicitud de visita guiada</p>
                </a>
            </div>
            <div class="card-footer text-center">
                <a href="admin-admissions.html" class="small">Ir al CRM de Admisiones</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0">Documentos Pendientes</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0 bg-light rounded p-2 text-center" style="width: 50px;">
                        <h4 class="mb-0 fw-bold text-dark">5</h4>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-0">Certificados de Escolaridad</h6>
                        <small class="text-muted">Solicitados hoy</small>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer"></i></button>
                </div>
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 bg-light rounded p-2 text-center" style="width: 50px;">
                        <h4 class="mb-0 fw-bold text-dark">2</h4>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-0">Record de Notas</h6>
                        <small class="text-muted">Para traslados</small>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>

{{/layout-main}}