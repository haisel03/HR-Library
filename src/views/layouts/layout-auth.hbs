<!DOCTYPE html>
<html lang="es">
{{> head}}

<body class="auth-body">
	<main class="d-flex w-100">
		<div class="container d-flex flex-column">
			<div class="row vh-100">
				<div class="col-sm-10 col-md-8 col-lg-6 col-xl-5 mx-auto d-flex align-items-center">

					<div class="w-100">

						<!-- 🔥 LOGO SEMÁNTICO -->
						<div class="text-center mb-4">

							<h1 class="auth-logo mb-3">
								<img src="img/logos/logo-login.svg" alt="HR Library" class="img-fluid" width="260">
							</h1>

							<h2 class="auth-title text-white fw-bold">
								{{title}}
							</h2>

							<p class="auth-description text-white-50 small mb-0">
								{{description}}
							</p>

						</div>

						{{> @partial-block}}

					</div>

				</div>
			</div>
		</div>
	</main>
</body>

</html>
