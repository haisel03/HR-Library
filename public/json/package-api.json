{
  "name": "hr-library-api",
  "version": "1.0.0",
  "description": "API de prueba para HR Library usando JSON Server",
  "scripts": {
    "api": "json-server --watch db.json --port 3001 --routes routes.json --middlewares middleware.js",
    "api:delay": "json-server --watch db.json --port 3001 --routes routes.json --middlewares middleware.js --delay 500",
    "api:reset": "node reset.js"
  },
  "dependencies": {
    "json-server": "^0.17.4"
  }
}
