{
  "source": {
    "include": [
      "src/js/HR.js"
    ],
    "includePattern": ".+\\.js$",
    "excludePattern": "(helpers|init|config|node_modules|docs)"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "template": "./node_modules/docdash",
    "tutorials": "./tutorials"
  },
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true
  }
}